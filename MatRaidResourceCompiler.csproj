<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
  </ItemGroup>

	<ItemGroup>
		<Content Include="SaintCoinach.Cmd\Definitions\**">
			<Link>\Definitions\%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
			<Visible>false</Visible>
		</Content>
	</ItemGroup>
		
	<ItemGroup>
	  <Reference Include="SaintCoinach">
	    <HintPath>SaintCoinach.Cmd\SaintCoinach.dll</HintPath>
	  </Reference>
	  <Reference Include="System.Drawing.Common">
	    <HintPath>SaintCoinach.Cmd\System.Drawing.Common.dll</HintPath>
	  </Reference>
	</ItemGroup>
	
</Project>
